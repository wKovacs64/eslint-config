{
  "name": "@wkovacs64/eslint-config",
  "version": "0.0.0-semantically-released",
  "description": "@wKovacs64 ESLint config",
  "keywords": [
    "eslint",
    "eslintconfig",
    "wkovacs64"
  ],
  "author": {
    "name": "Justin Hall",
    "email": "justin.r.hall@gmail.com"
  },
  "license": "MIT",
  "main": "index.js",
  "files": [
    "index.js",
    "base",
    "react",
    "ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/wKovacs64/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/wKovacs64/eslint-config/issues"
  },
  "scripts": {
    "cm": "git-cz",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md,yml}\"",
    "lint": "eslint .",
    "validate": "yarn lint"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^1.1.0",
    "@typescript-eslint/parser": "^1.1.0",
    "babel-eslint": "^10.0.1",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-config-prettier": "^4.0.0",
    "eslint-plugin-import": "^2.15.0",
    "eslint-plugin-jsx-a11y": "^6.2.0",
    "eslint-plugin-react": "^7.12.4",
    "eslint-plugin-react-hooks": "^0.0.0",
    "typescript": "^3.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "7.5.0",
    "@commitlint/config-conventional": "7.5.0",
    "commitizen": "3.0.5",
    "cz-conventional-changelog": "2.1.0",
    "eslint": "5.12.1",
    "husky": "1.3.1",
    "lint-staged": "8.1.1",
    "prettier": "1.16.3",
    "semantic-release": "15.13.3"
  },
  "peerDependencies": {
    "eslint": ">= 5"
  }
}
